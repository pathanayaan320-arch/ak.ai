# =========================================================================
# AK.AI - ENVIRONMENT VARIABLES TEMPLATE
# =========================================================================
# Copy this file to .env and configure the variables with your own credentials.
# NEVER commit the real .env file with actual secrets to git!

# GEMINI AI API Configuration
# AI Studio automatically injects GEMINI_API_KEY at runtime from your secrets panel.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# App Deployment Host URL (automatically injected on Cloud Run)
APP_URL="YOUR_APP_DEPLOYMENT_URL_HERE"

# Firebase Config (Automatically read from firebase-applet-config.json if not specified here)
FIREBASE_PROJECT_ID="YOUR_FIREBASE_PROJECT_ID_HERE"
FIREBASE_APP_ID="YOUR_FIREBASE_APP_ID_HERE"
FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY_HERE"
FIREBASE_AUTH_DOMAIN="YOUR_FIREBASE_AUTH_DOMAIN_HERE"
FIREBASE_STORAGE_BUCKET="YOUR_FIREBASE_STORAGE_BUCKET_HERE"
FIREBASE_MESSAGING_SENDER_ID="YOUR_FIREBASE_MESSAGING_SENDER_ID_HERE"
FIREBASE_DATABASE_ID="YOUR_FIREBASE_DATABASE_ID_HERE"

# Instagram DM Comment-to-DM Automation Config
# Encryption Key (MUST be exactly 32 characters/bytes for AES-256-CBC)
INSTAGRAM_TOKEN_ENC_KEY="YOUR_32_CHAR_ENCRYPTION_KEY_HERE"

# Instagram Webhook Verification Token (custom handshake handshake string)
INSTAGRAM_WEBHOOK_VERIFY_TOKEN="YOUR_WEBHOOK_VERIFY_TOKEN_HERE"

# Meta Developer App Settings (For long-lived Token Exchange & Signature Check)
INSTAGRAM_APP_SECRET="YOUR_META_APP_SECRET_HERE"
INSTAGRAM_APP_ID="YOUR_META_APP_ID_HERE"
